{
  "expo": {
    "name": "Twitter Sentiment",
    "slug": "twitter-sentiment",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1DA1F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.invistico.twittersentiment",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1DA1F2"
      },
      "package": "com.invistico.twittersentiment",
      "usesCleartextTraffic": true
    },
    "extra": {
      "apiUrl": "http://127.0.0.1:5055"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ]
  }
}
